<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.0" snapToGrid="true">
  <code><![CDATA[extensions [ rnd ] ;; Required at the top of your script for the efficient weighted lottery

breed [ individuals individual ]
breed [ social-sets social-set ]
undirected-link-breed [ memberships membership ]
undirected-link-breed [ set-links set-link ]

individuals-own [
  strategy
  fitness
  degree
  local-c-freq
]

to setup
  clear-all
  
  ;; 1. Initialize the sets (M)
  create-social-sets M [
    hide-turtle 
  ]
  
  ;; 2. Initialize the individuals (N)
  create-individuals N [
    
    ;; Assign random strategy (50/50)
    set strategy ifelse-value (random 2 = 0) [ "Cooperator" ] [ "Defector" ]
    
    ;; Determine number of sets
    let num-sets round random-normal K std
    
    ;; Safety checks for boundaries
    if num-sets < 1 [ set num-sets 1 ]
    if num-sets > M [ set num-sets M ]
    
    ;; Assign strictly unique sets using n-of
    let my-assigned-sets n-of num-sets social-sets
    
    ;; Create the network connections
    create-memberships-with my-assigned-sets
  ]
  
  visualize-sets
  
  reset-ticks
end

to go
  evolutionary-step
    visualize-sets
  tick
end

to evolutionary-step
  ;; STEP A: Generate payoff and fitness
  ask individuals [
    let my-strat strategy
    
    ;; Sum the sizes of all my sets (minus myself) to get multiplicity counts
    let neigh-total sum [ count membership-neighbors - 1 ] of membership-neighbors
    
    ;; Sum the cooperators in all my sets (subtracting 1 if I am a cooperator)
    let neigh-coop sum [ 
      count membership-neighbors with [strategy = "Cooperator"] - ifelse-value (my-strat = "Cooperator") [1] [0] 
    ] of membership-neighbors
    
    ;; --- TRACKING VARIABLES ---
    set degree neigh-total
    set local-c-freq ifelse-value (degree > 0) [ neigh-coop / degree ] [ 0 ]
    
    ;; Calculate payoff
    let payoff 0
    if neigh-total > 0 [
      set payoff (b * neigh-coop) / (neigh-total ^ (1 - s))
    ]
    
    if my-strat = "Cooperator" [
      set payoff payoff - c
    ]
    
    set fitness w0 + payoff
    
    ;; Prevent negative weights in the roulette wheel
    if fitness < 0 [ set fitness 0 ] 
  ]
  
  ;; STEP B: Death and Reproduction
  let deceased one-of individuals
  
  ;; turtle-set automatically removes duplicates, ensuring unique neighbors only
  let unique-neighbors (turtle-set [membership-neighbors] of [membership-neighbors] of deceased) with [self != deceased]
  
  let candidates unique-neighbors
  
  ;; Fallback to global lottery if the deceased had no neighbors
  if not any? candidates [
    set candidates individuals with [self != deceased]
  ]
  
  ;; Run the weighted lottery using the rnd extension
  let winner rnd:weighted-one-of candidates [ fitness ]
  
  ask winner [
    ;; Hatch 1 offspring. It automatically copies 'strategy' but NOT the links.
    hatch-individuals 1 [
      
      ;; RULE 1: Trait Mutation (u)
      ;; If we roll under u, randomize strategy. (Otherwise, it keeps the inherited one).
      if random-float 1.0 < u [
        set strategy ifelse-value (random 2 = 0) [ "Cooperator" ] [ "Defector" ]
      ]
      
      ;; Reset fitness for the new life
      set fitness 0 
      
      ;; RULE 2: Independent Set Mutation (v) & Directed Exploration (X)
      let parent-sets [membership-neighbors] of myself
      
      ;; Pre-calculate the parent's neighbors' sets for Directed Exploration
      let parent-neighbors (turtle-set [membership-neighbors] of parent-sets) with [self != myself]
      let neighbor-sets turtle-set [membership-neighbors] of parent-neighbors
      
      let target-sets []
      
      ;; Loop through each of the parent's sets independently
      ask parent-sets [
        let chosen-set self
        
        ;; Roll for Set Mutation
        if random-float 1.0 < v [
          
          ;; Roll for Directed Exploration vs Random Jump
          ;; (We also check if neighbor-sets actually exist, fallback to random if isolated)
          ifelse (random-float 1.0 < X) and (any? neighbor-sets) [
            set chosen-set one-of neighbor-sets
          ] [
            set chosen-set one-of social-sets
          ]
        ]
        
        ;; Add to our temporary list
        set target-sets lput chosen-set target-sets
      ]
      
      ;; Enforce uniqueness: converting a list to a turtle-set destroys any duplicates
      let final-unique-sets turtle-set target-sets
      
      ;; Uniqueness Collision Fallback: If a mutation caused a duplicate, 
      ;; the offspring is now short one set. Fill the gap with random sets.
      while [ count final-unique-sets < count parent-sets ] [
        set final-unique-sets (turtle-set final-unique-sets (one-of social-sets))
      ]
      
      ;; Finally, create the physical network links to the chosen sets
      create-memberships-with final-unique-sets
    ]
  ]
  
  ;; The deceased finally dies, removing itself and all its links from the network
  ask deceased [ die ]
end

to visualize-sets
  ;; 1. Hide individuals and raw bipartite links
  ask individuals [ hide-turtle ]
  ask memberships [ hide-link ]
  
  ;; 2. Make sets visible as balls and set properties
  ask social-sets [
    show-turtle
    set shape "circle"
    set size 1.5
    
    let my-members membership-neighbors
    let num-members count my-members
    
    ;; Set the number label
    set label num-members
    
    ;; Calculate color (NetLogo grayscale: 0 is black, 9.9 is white)
    ifelse num-members > 0 [
      let coops count my-members with [strategy = "Cooperator"]
      set color (coops / num-members) * 9.9
    ] [
      set color turquoise ;; Fallback for empty sets
    ]
  ]
  
  ;; 3. Clear old visualization links
  ask set-links [ die ]
  
  ;; 4. Draw new links between sets proportional to shared individuals
  ask social-sets [
    let setA self
    ask other social-sets with [self > setA] [
      
      ;; USE membership-neighbor? TO ISOLATE THE COUNT
      let shared-count count membership-neighbors with [membership-neighbor? setA]
      
      if shared-count > 0 [
        ask setA [
          create-set-link-with myself [
            set thickness 0.1 ;; Fixed standard width
            ;; Scales from dark red/black (0) to bright red (10+). Adjust the 10 to your expected max.
            set color scale-color red shared-count 0 10
          ]
        ]
      ]
    ]
  ]
  
  ;; 5. Apply network layout to space them out (looser springs)
  ;; Decreased spring constant, increased resting length, increased repulsion
  repeat 3 [ layout-spring social-sets set-links 0.2 10 2 ]
end
]]></code>
