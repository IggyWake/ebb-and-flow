        </enumeratedValueSet>
        <enumeratedValueSet variable="s">
          <value value="0"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="u">
          <value value="0"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="v">
          <value value="0"></value>
          <value value="0.2"></value>
