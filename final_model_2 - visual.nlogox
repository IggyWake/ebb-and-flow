    <view x="390" wrappingAllowedX="true" y="20" frameRate="30.0" minPycor="-16" height="399" showTickCounter="true" patchSize="11.97" fontSize="10" wrappingAllowedY="true" width="399" tickCounterLabel="ticks" maxPycor="16" updateMode="1" maxPxcor="16" minPxcor="-16"></view>
