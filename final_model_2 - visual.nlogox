    <input x="25" multiline="false" y="280" height="60" variable="w0" type="number" width="100">10.0</input>
    <note x="255" y="250" backgroundDark="-3026479" fontSize="12" width="120" markdown="false" height="24" textColorDark="-14737633" textColorLight="-16777216" backgroundLight="0">Cooperation benefit</note>
    <input x="255" multiline="false" y="280" height="60" variable="b" type="number" width="120">40.0</input>
    <input x="130" multiline="false" y="280" height="60" variable="c" type="number" width="120">10.0</input>
    <note x="25" y="250" backgroundDark="-3026479" fontSize="12" width="100" markdown="false" height="24" textColorDark="-14737633" textColorLight="-16777216" backgroundLight="0">Baseline fitness</note>
    <input x="25" multiline="false" y="170" height="60" variable="N" type="number" width="100">200.0</input>
    <note x="25" y="140" backgroundDark="-3026479" fontSize="12" width="100" markdown="false" height="24" textColorDark="-14737633" textColorLight="-16777216" backgroundLight="0">Population</note>
    <note x="130" y="250" backgroundDark="-3026479" fontSize="12" width="120" markdown="false" height="24" textColorDark="-14737633" textColorLight="-16777216" backgroundLight="0">Cooperation cost</note>
    <note x="130" y="140" backgroundDark="-3026479" fontSize="12" width="100" markdown="false" height="24" textColorDark="-14737633" textColorLight="-16777216" backgroundLight="0">Total sets</note>
    <note x="235" y="130" backgroundDark="-3026479" fontSize="12" width="100" markdown="false" height="36" textColorDark="-14737633" textColorLight="-16777216" backgroundLight="0">Set distribution 
mean</note>
    <input x="235" multiline="false" y="170" height="60" variable="K" type="number" width="100">2.0</input>
    <button x="90" y="20" height="40" disableUntilTicks="false" forever="true" kind="Observer" width="66" display="go">go</button>
    <plot x="385" autoPlotX="false" yMax="20.0" autoPlotY="false" yAxis="Count" y="435" xMin="0.0" height="155" legend="false" xMax="1000.0" yMin="0.0" width="210" xAxis="Degree (k)" display="Degree Distribution C">
      <setup></setup>
      <update>set-histogram-num-bars M</update>
      <pen interval="1.0" mode="1" display="Cooperators" color="-11033397" legend="true">
        <setup></setup>
        <update>histogram [degree] of individuals with [strategy = "Cooperator"]</update>
      </pen>
    </plot>
    <plot x="615" autoPlotX="true" yMax="100.0" autoPlotY="false" yAxis="Count" y="595" xMin="0.0" height="155" legend="false" xMax="50.0" yMin="0.0" width="210" xAxis="Number of Sets" display="Set  Distribution D">
      <setup></setup>
      <update>set-histogram-num-bars M</update>
      <pen interval="1.0" mode="1" display="Defectors" color="-5298144" legend="true">
        <setup></setup>
        <update>histogram [count membership-neighbors] of individuals with [strategy = "Defector"]</update>
      </pen>
    </plot>
    <plot x="615" autoPlotX="false" yMax="20.0" autoPlotY="false" yAxis="Count" y="435" xMin="0.0" height="155" legend="false" xMax="1000.0" yMin="0.0" width="210" xAxis="Degree (k)" display="Degree Distribution D">
      <setup></setup>
      <update>set-histogram-num-bars M</update>
      <pen interval="1.0" mode="1" display="Defectors" color="-5298144" legend="true">
        <setup></setup>
        <update>histogram [degree] of individuals with [strategy = "Defector"]</update>
      </pen>
    </plot>
    <slider x="25" step="0.01" y="480" max="1" width="150" display="s" height="50" min="0" direction="Horizontal" default="0.21" variable="s"></slider>
    <button x="30" y="20" height="40" disableUntilTicks="false" forever="false" kind="Observer" width="55" display="setup">setup</button>
    <monitor x="840" precision="17" y="440" height="60" fontSize="11" width="100" display="cooperators">count individuals with [strategy = "Cooperator"]</monitor>
    <monitor x="840" precision="17" y="510" height="60" fontSize="11" width="100" display="coop prop">count individuals with [strategy = "Cooperator"] / N</monitor>
    <monitor x="945" precision="17" y="440" height="60" fontSize="11" width="100" display="defectors">count individuals with [strategy = "Defector"]</monitor>
    <monitor x="945" precision="17" y="510" height="60" fontSize="11" width="100" display="def prop">count individuals with [strategy = "Defector"] / N</monitor>
    <plot x="810" autoPlotX="true" yMax="1.0" autoPlotY="false" y="25" xMin="0.0" height="370" legend="true" xMax="1.0" yMin="0.0" width="525" xAxis="Generation (Time)" display="Cooperator proportion vs Assortment">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="Cooperator Proportion" color="-14737633" legend="true">
        <setup></setup>
        <update>plot count individuals with [strategy = "Cooperator"] / N</update>
      </pen>
      <pen interval="1.0" mode="0" display="Assortment" color="-7500403" legend="true">
        <setup></setup>
        <update>plot ifelse-value (any? individuals with [strategy = "Cooperator"]) [ mean [local-c-freq] of individuals with [strategy = "Cooperator"] ] [ 0 ]</update>
      </pen>
      <pen interval="1.0" mode="0" display="Variance Ratio" color="-13403783" legend="true">
        <setup></setup>
        <update>plot ifelse-value (any? individuals with [strategy = "Cooperator"]) [ mean [local-c-freq] of individuals with [strategy = "Cooperator"] - mean [local-c-freq] of individuals with [strategy = "Defector"] ] [ 0 ]</update>
      </pen>
    </plot>
    <plot x="385" autoPlotX="true" yMax="100.0" autoPlotY="false" yAxis="Count" y="595" xMin="0.0" height="155" legend="false" xMax="50.0" yMin="0.0" width="210" xAxis="Number of Sets" display="Set Distribution C">
      <setup></setup>
      <update>set-histogram-num-bars M</update>
      <pen interval="1.0" mode="1" display="Cooperators" color="-11033397" legend="true">
        <setup></setup>
        <update>histogram [count membership-neighbors] of individuals with [strategy = "Cooperator"]</update>
      </pen>
    </plot>
  </widgets>
