  <previewCommands>setup repeat 75 [ go ]</previewCommands>
  <experiments>
    <experiment name="Experiment 1 (Andrés)" repetitions="2" sequentialRunOrder="true" runMetricsEveryStep="false" timeLimit="5000">
      <setup>setup</setup>
      <go>go</go>
      <exitCondition>u = 0 and (count individuals with [strategy = "Cooperator"] = 0 or count individuals with [strategy = "Defector"] = 0)</exitCondition>
      <runMetricsCondition>ticks mod 100 = 0</runMetricsCondition>
      <metrics>
        <metric>(count individuals with [strategy = "Cooperator"]) / N</metric>
        <metric>ifelse-value (any? individuals with [strategy = "Cooperator"]) [ mean [local-c-freq] of individuals with [strategy = "Cooperator"] ] [ 0 ]</metric>
        <metric>ifelse-value (any? individuals with [strategy = "Defector"]) [ mean [local-c-freq] of individuals with [strategy = "Defector"] ] [ 0 ]</metric>
        <metric><![CDATA[ifelse-value (count individuals with [strategy = "Cooperator"] > 1) [ standard-deviation [local-c-freq] of individuals with [strategy = "Cooperator"] ] [ 0 ]]]></metric>
        <metric><![CDATA[ifelse-value (count individuals with [strategy = "Defector"] > 1) [ standard-deviation [local-c-freq] of individuals with [strategy = "Defector"] ] [ 0 ]]]></metric>
        <metric>[degree] of individuals with [strategy = "Cooperator"]</metric>
        <metric>[degree] of individuals with [strategy = "Defector"]</metric>
        <metric>[count link-neighbors] of individuals with [strategy = "Cooperator"]</metric>
        <metric>[count link-neighbors] of individuals with [strategy = "Defector"]</metric>
        <metric>[ count membership-neighbors ] of social-sets</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="b">
          <value value="20"></value>
          <value value="25"></value>
          <value value="30"></value>
          <value value="35"></value>
          <value value="40"></value>
